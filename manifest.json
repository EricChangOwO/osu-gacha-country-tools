{
  "manifest_version": 3,
  "name": "osu!gacha Country Tools",
  "version": "0.1.6",
  "description": "Adds country grouping and collection utilities to gacha.miz.to.",
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "action": {
    "default_title": "osu!gacha Country Tools",
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png"
    }
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://gacha.miz.to/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://gacha.miz.to/*"
      ],
      "js": [
        "src/content/utils.js",
        "src/content/data.js",
        "src/content/toolbar.js",
        "src/content/grid.js",
        "src/content/auto-open.js",
        "src/content/main.js"
      ],
      "css": [
        "src/content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/bridge/page-bridge.js"
      ],
      "matches": [
        "https://gacha.miz.to/*"
      ]
    }
  ]
}
